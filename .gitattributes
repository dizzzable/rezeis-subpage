# Normalize line endings to LF for the whole repo.
# Prevents CRLF (from Windows checkouts with core.autocrlf=true) being committed,
# which the prettier config (endOfLine: lf) would otherwise reject in CI.
* text=auto eol=lf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

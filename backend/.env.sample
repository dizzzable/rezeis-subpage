APP_PORT=3010

### Remnawave Panel URL — used ONLY for subscription DATA (not for config).
### Can be http://remnawave:3000 (docker network) or https://panel.example.com
REMNAWAVE_PANEL_URL=https://remnawave:3000
### API Token from Remnawave Dashboard → Settings → API Tokens
REMNAWAVE_API_TOKEN=

### ─────────────────────────────────────────────────────────────────────────
### CONFIG SOURCE — pick ONE:
###  (A) Mounted file  → set SUBPAGE_CONFIG_FILE (classic "download from panel
###      → mount into container" workflow). Takes precedence if set.
###  (B) rezeis-admin   → set REZEIS_ADMIN_URL + REZEIS_ADMIN_TOKEN (live, with
###      TTL refresh + invalidate webhook).
### ─────────────────────────────────────────────────────────────────────────

# (A) Path to a mounted config JSON (download it from the rezeis-admin editor:
#     "Subscription page" → Download). Mount it read-only in docker-compose, e.g.
#     volumes: ["./subpage-config.json:/opt/app/config/subpage-config.json:ro"]
# When set, rezeis-admin vars below are optional.
SUBPAGE_CONFIG_FILE=

# (B) rezeis-admin — source of truth for the config (branding, app catalog,
#     baseSettings, theme). Required UNLESS SUBPAGE_CONFIG_FILE is set.
REZEIS_ADMIN_URL=http://rezeis:8000
# Auth token for calling rezeis-admin (Bearer; mint in Settings → API tokens).
REZEIS_ADMIN_TOKEN=
# Shared secret for the inbound invalidate webhook (rezeis-admin → subpage).
# Leave empty to disable the webhook (config still refreshes on TTL).
REZEIS_SUBPAGE_WEBHOOK_SECRET=
# How long (seconds) a fetched config is considered fresh before a background
# refresh is triggered. Default 300.
SUBPAGE_CONFIG_TTL_SECONDS=300

# Secret used to sign the short-lived browser session cookie (JWT) that gates
# static assets and the app-config route. Generate: openssl rand -hex 32
INTERNAL_JWT_SECRET=

# Serve at a custom root path, e.g. CUSTOM_SUB_PREFIX=sub
# Do not place / at the start/end.
CUSTOM_SUB_PREFIX=

# Express `trust proxy` setting. Accepts:
#   - "true" / "false"                          -> trust all / none
#   - a non-negative integer (e.g. 1, 2)        -> number of trusted hops
#   - a comma-separated list of preset names    -> loopback, linklocal, uniquelocal
#     and/or IP addresses / CIDR subnets        -> e.g. 127.0.0.1, 172.16.0.0/12
TRUST_PROXY=1

# If you use "Caddy with security" addon or "Tiny Auth" in front of Remnawave.
CADDY_AUTH_API_TOKEN=

# If you use Cloudflare Zero Trust in front of Remnawave.
CLOUDFLARE_ZERO_TRUST_CLIENT_ID=""
CLOUDFLARE_ZERO_TRUST_CLIENT_SECRET=""

# Optional raw Cookie header for requests to Remnawave (edge cases).
EGAMES_COOKIE=

# Support Marzban legacy links
MARZBAN_LEGACY_LINK_ENABLED=false
MARZBAN_LEGACY_SECRET_KEY=
# Example format: "2025-01-17T15:38:45.065Z"
MARZBAN_LEGACY_SUBSCRIPTION_VALID_FROM=
MARZBAN_LEGACY_DROP_REVOKED_SUBSCRIPTIONS=false
